APP_NAME=ePathways
APP_ENV=local
APP_KEY=base64:Jimdd6ExP1tVVwT6Nx20k8JoMZ+gAfJaUG0Ii/pSPQc=
APP_DEBUG=true
APP_URL=https://staging.epathways.co.nz

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=epathways
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

CALENDAR_SYNC_TOKEN=epathways_sync_2026_safe
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b
OPENAI_API_KEY=
GEMINI_API_KEY=

# Stripe Checkout — used by the resident-intake payment step.
# Test keys start with `pk_test_` / `sk_test_`; live keys with `pk_live_` /
# `sk_live_`. STRIPE_WEBHOOK_SECRET comes from the Stripe dashboard's
# Developers → Webhooks → endpoint signing secret.
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# PLAI Partner API — AI ad launcher (FB / IG / Google / LinkedIn / TikTok).
# Get keys from PLAI dashboard → profile → Developer Center (Enterprise plan).
PLAI_API_KEY=
PLAI_BASE_URL=https://partner.plai.io
PLAI_WORKSPACE_ID=

# Social MVP — n8n workflow for stats, variant generation, approval,
# scheduling, accounts, quick posts. Leave blank to run the UI on stub
# fixtures during early development.
SOCIAL_WEBHOOK_BASE=
SOCIAL_WEBHOOK_SECRET=
